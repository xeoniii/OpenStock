<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.OpenStock" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/mint_primary</item>
        <item name="colorPrimaryVariant">@color/mint_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/mint_primary</item>
        <item name="colorSecondaryVariant">@color/mint_dark</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/background_dark</item>

        <!-- Custom Material Components Styles -->
        <item name="materialAlertDialogTheme">@style/Theme.OpenStock.AlertDialog</item>
        <item name="textInputStyle">@style/Widget.OpenStock.TextInputLayout</item>
        <item name="materialButtonStyle">@style/Widget.OpenStock.Button.Primary</item>
    </style>

    <!-- Dialog Style -->
    <style name="Theme.OpenStock.AlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="materialAlertDialogTitleTextStyle">@style/Theme.OpenStock.AlertDialog.Title</item>
        <item name="materialAlertDialogBodyTextStyle">@style/Theme.OpenStock.AlertDialog.Body</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.OpenStock.Button.Primary.Dialog</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.OpenStock.Button.Primary.Dialog</item>
        <item name="buttonBarNeutralButtonStyle">@style/Widget.OpenStock.Button.Primary.Dialog</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.OpenStock.Dialog</item>
        <item name="colorSurface">@color/background_dark</item>
    </style>

    <style name="ShapeAppearance.OpenStock.Dialog" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <style name="Theme.OpenStock.Dialog" parent="Theme.MaterialComponents.DayNight.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:background">@drawable/bg_dialog_custom</item>
        <item name="android:windowFrame">@null</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <style name="Theme.OpenStock.AlertDialog.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Theme.OpenStock.AlertDialog.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/glass_text_secondary</item>
    </style>

    <!-- TextInputLayout Style -->
    <style name="Widget.OpenStock.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">#1F2225</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/text_input_stroke_color</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="hintTextColor">@color/mint_primary</item>
        <item name="android:textColorHint">@color/glass_text_secondary</item>
        <item name="boxStrokeWidthFocused">1.5dp</item>
    </style>

    <!-- Button Style -->
    <style name="Widget.OpenStock.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/black</item>
        <item name="iconTint">@color/black</item>
        <item name="backgroundTint">@color/mint_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.OpenStock.Button.Primary.Dialog" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/mint_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
    </style>
</resources>
