<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Group totals summary -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#17202A">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <LinearLayout
                        android:id="@+id/layoutCost"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvCostLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="COST"
                            android:textSize="10sp"
                            android:textColor="#E67E22" />
                        <TextView
                            android:id="@+id/tvTotalWholesale"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AED 0.00"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#E67E22" />
                    </LinearLayout>

                    <View android:id="@+id/divider1" android:layout_width="1dp" android:layout_height="36dp"
                        android:background="#444" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvPriceLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="REVENUE"
                            android:textSize="10sp"
                            android:textColor="#27AE60" />
                        <TextView
                            android:id="@+id/tvTotalRetail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AED 0.00"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#27AE60" />
                    </LinearLayout>

                    <View android:id="@+id/divider2" android:layout_width="1dp" android:layout_height="36dp"
                        android:background="#444" />

                    <LinearLayout
                        android:id="@+id/layoutProfit"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PROFIT"
                            android:textSize="10sp"
                            android:textColor="#3498DB" />
                        <TextView
                            android:id="@+id/tvTotalProfit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AED 0.00"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#3498DB" />
                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCompleteSale"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="14dp"
                    android:layout_marginBottom="14dp"
                    android:text="Complete Sale"
                    android:backgroundTint="#27AE60"
                    app:cornerRadius="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerSaleItems"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="8dp"
            android:clipToPadding="false"
            android:paddingBottom="80dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginTop="120dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🛒"
            android:textSize="56sp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No items in this sale"
            android:textSize="18sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginTop="8dp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap + to add items"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabScanItem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="80dp"
        android:layout_marginBottom="16dp"
        app:fabSize="mini"
        android:contentDescription="Scan Item"
        android:src="@android:drawable/ic_menu_camera" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddItem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:contentDescription="Add Item"
        android:src="@android:drawable/ic_input_add" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
